APP_ENV=local
APP_DEBUG=1
APP_URL=http://localhost:8000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_name
DB_USER=usr_name
DB_PASS=change_me

# OpenRouter (gateway unificado para todos los modelos)
# https://openrouter.ai - Acceso a Gemini, GPT, Claude, Qwen, etc.
# openrouter/auto = selección automática inteligente del mejor modelo
OPENROUTER_API_KEY=change_me
OPENROUTER_MODEL=openrouter/auto

# Google AI Studio (para Gemini TTS - generación de audio)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=change_me

# Audio transcription
# Provider selection reserved for next phase (OpenRouter fallback).
AUDIO_TRANSCRIBE_PROVIDER=auto
GEMINI_TRANSCRIBE_MODEL=gemini-3-flash-preview
OPENROUTER_TRANSCRIBE_MODEL=google/gemini-3-flash-preview
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
GEMINI_TRANSCRIBE_CONCURRENCY=5

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

# Qdrant (vector database para RAG)
# Los embeddings usan OpenRouter con qwen/qwen3-embedding-8b
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Background jobs
# Increase if long transcriptions/podcasts need more runtime.
BACKGROUND_JOB_MAX_SECONDS=4500
